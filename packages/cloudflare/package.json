  },
  "dependencies": {
    "agent-ready-web": "workspace:*"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": ">=4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agent-readiness",
    "cloudflare-workers",
    "robots",
    "sitemap"
  ]
}
