{
  "name": "@agent-ready-web/next",
  "version": "0.1.0",
  "description": "Next.js App Router adapters for agent-ready-web.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lexabu/agent-ready-web.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/lexabu/agent-ready-web#readme",
  "bugs": "https://github.com/lexabu/agent-ready-web/issues",
  "type": "module",
  "main": "./dist/index.js",
